# Supabase
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_LEADS_INSERT_KEY=sb_secret_insert_key_replace_me
SUPABASE_LEADS_TABLE=leads

# Origens permitidas
SITE_URL=https://cdcentralrastreamento.com.br
ALLOWED_ORIGINS=https://cdcentralrastreamento.com.br,https://your-preview.vercel.app
# Em producao, a API exige Origin valido por padrao. Use 1 apenas para integracoes server-to-server controladas.
# ALLOW_MISSING_ORIGIN=0

# Cloudflare Turnstile
TURNSTILE_SITE_KEY=0x4AAAA_public_site_key
TURNSTILE_SECRET_KEY=0x4AAAA_private_secret_key

# Rate limit distribuido com Upstash Redis ou Vercel KV compativel com Upstash.
UPSTASH_REDIS_REST_URL=https://your-redis.upstash.io
UPSTASH_REDIS_REST_TOKEN=your_upstash_rest_token
# Alternativa Vercel KV:
# KV_REST_API_URL=https://your-kv.upstash.io
# KV_REST_API_TOKEN=your_kv_rest_token

# A tabela deve aceitar os campos:
# nome, whatsapp, tipo, veiculos, consent_at, consent_version, consent_ip
